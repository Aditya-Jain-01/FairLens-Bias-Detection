# ═══════════════════════════════════════════════════════════════════════════════
# FairLens — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Secrets (NEVER commit) ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Internal team documents (not for public repo) ────────────────────────────
docs/prompts/

# ── Python ───────────────────────────────────────────────────────────────────
venv/
env/
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# ── Local runtime storage (generated at runtime, not source code) ────────────
backend/storage_local/

# ── Node / Next.js ───────────────────────────────────────────────────────────
node_modules/
.next/
/out/
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
next-env.d.ts
.vercel

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Misc ─────────────────────────────────────────────────────────────────────
*.pem
/coverage
