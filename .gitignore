# ═══════════════════════════════════════════════════════════════════════════════
# FairLens — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
*.env
**/service-account*.json
**/gcloud-key*.json
**/credentials.json

# ── Internal team documents ───────────────────────────────────────────────────
docs/prompts/
docs/CONTRACT.md
CONTRACT.md
task.md
bugs_found.md

# ── Python ───────────────────────────────────────────────────────────────────
venv/
env/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
*.log

# ── ML artifacts — large binary files, generated at runtime ──────────────────
# Trained model checkpoints (keep source training scripts, not the outputs)
*.pkl
*.onnx
*.h5
*.pt
*.pth
# Exception: demo models in test_data/ ARE committed (small, needed for demos)
!test_data/*.pkl
!test_data/*.onnx

# ── Local runtime storage (generated at runtime, never source code) ───────────
backend/storage_local/
storage_local/

# ── Duplicated build files ───────────────────────────────────────────────────
backend/test_data/

# ── Results and reports generated during development ─────────────────────────
results_partial.json
*.pdf
!docs/*.pdf

# ── Node / Next.js ───────────────────────────────────────────────────────────
node_modules/
.next/
/out/
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
next-env.d.ts
.vercel

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
/coverage